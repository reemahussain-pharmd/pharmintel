# PharmIntel — Environment Variables Template
# Copy this file to .env and fill in your real values
# NEVER commit .env to GitHub — it is in .gitignore

# Google Gemini AI (free tier) — get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase — get from https://supabase.com → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# PubMed / NCBI (use your email address — required by NCBI)
PUBMED_EMAIL=your_email@example.com

# Backend URL
# Local development:
BACKEND_URL=http://localhost:8000
# After deploying to Render.com, change to your Render URL:
# BACKEND_URL=https://pharmintel-api.onrender.com
